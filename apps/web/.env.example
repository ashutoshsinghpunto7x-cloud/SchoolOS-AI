# Copy this file to .env and fill in your values
# Never commit .env to version control

VITE_API_BASE_URL=https://schoolos-ai-eeiy.onrender.com/api/v1
VITE_APP_ENV=development

# Production build (apps/web/.env.production, also gitignored): set
# VITE_API_BASE_URL to the deployed backend, e.g.
#   VITE_API_BASE_URL=https://schoolos-ai-eeiy.onrender.com/api/v1
# This local file alone does NOT configure the actual Vercel deployment —
# Vercel builds from git, and .env.production is gitignored, so the same
# VITE_API_BASE_URL must also be set as an Environment Variable in the
# Vercel project's dashboard (Settings → Environment Variables) for the
# live, domain-connected site to use it.
