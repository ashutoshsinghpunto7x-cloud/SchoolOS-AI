# ============================================================
# SchoolOS AI — Environment Variables Reference
# Copy the server block into apps/server/.env
# Copy the frontend block into apps/web/.env
# NEVER commit .env files to version control.
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Rotate production credentials before go-live.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Allowed CORS origin (frontend URL)
FRONTEND_URL=http://localhost:5173

# School display name (used in notifications, emails, etc.)
SCHOOL_NAME=Sunrise Academy

# ── JWT Secrets ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<generate-a-64-byte-hex-string>
JWT_REFRESH_SECRET=<generate-a-different-64-byte-hex-string>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Rate Limiting ────────────────────────────────────────────
# Window in ms (default: 900000 = 15 min). Max requests per window.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Integration Credential Encryption ───────────────────────
# AES-256-GCM key for encrypting provider credentials at rest.
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=<generate-a-64-char-hex-string>

# ── n8n Automation ───────────────────────────────────────────
# Webhook URL exposed by your n8n instance.
# Leave blank to run in simulation mode (no real n8n calls).
# The frontend MUST NEVER call n8n directly — only the server does.
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/<router-id>

# Shared secret n8n sends in the X-Automation-Secret header.
AUTOMATION_WEBHOOK_SECRET=<generate-a-random-secret>

# ── AI — OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── AI — Vapi (Voice Calls) ──────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# ── AI — ElevenLabs (Text-to-Speech) ────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── FRONTEND ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_APP_ENV=development
